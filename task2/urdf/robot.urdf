<?xml version="1.0"?>
<robot name="robot2">

  <material name="orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- BASE FOOTPRINT -->
  <link name="base_footprint"/>
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 -1.5708"/>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/bot_body.stl" scale="0.15 0.15 0.15"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>

      <geometry>
         <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/bot_body.stl" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0"
               izz="0.1"/>
    </inertial>
  </link>
  <gazebo reference="base_link"><material>Gazebo/Orange</material></gazebo>

  <!-- LEFT WHEEL -->
  <joint name="joint_wheel_left" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.1875 -0.15" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="wheel_left">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/wheel.stl" scale="0.38 0.38 0.38"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/wheel.stl" scale="0.38 0.38 0.38"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="wheel_left"><material>Gazebo/Black</material></gazebo>

  <!-- RIGHT WHEEL -->
  <joint name="joint_wheel_right" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.1875 -0.15" rpy="1.5708 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>
  <link name="wheel_right">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/wheel.stl" scale="0.38 0.38 0.38"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/wheel.stl" scale="0.38 0.38 0.38"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>
  </link>
  <gazebo reference="wheel_right"><material>Gazebo/Black</material></gazebo>

  <!-- FRONT CASTER PART -->
  <joint name="joint_caster_part_front" type="continuous">
    <parent link="base_link"/>
    <child link="caster_part_front"/>
    <origin xyz="0.15 0 -0.15" rpy="-1.5708 0 -1.5708"/>
    <axis xyz= "0 1 0"/>
  </joint>
  <link name="caster_part_front">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_part.stl" scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_part.stl" scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="caster_part_front"><material>Gazebo/Grey</material></gazebo>

  <!-- FRONT CASTER WHEEL -->
  <joint name="joint_caster_wheel_front" type="continuous">
    <parent link="caster_part_front"/>
    <child link="caster_wheel_front"/>
    <origin xyz="0 0.044 0.018" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="caster_wheel_front">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_wheel.stl" scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_wheel.stl" scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
<gazebo reference="caster_wheel_back">
  <mu1 value="0.1"/>
  <mu2 value="0.1"/>
</gazebo>


  <!-- REAR CASTER PART -->
  <joint name="joint_caster_part_back" type="continuous">
    <parent link="base_link"/>
    <child link="caster_part_back"/>
    <origin xyz="-0.17 0 -0.15" rpy="-1.5708 0 -1.5708"/>
       <axis xyz="0 1 0"/>
  </joint>
  <link name="caster_part_back">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_part.stl" scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_part.stl" scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
  <gazebo reference="caster_part_back"><material>Gazebo/Grey</material></gazebo>

  <!-- REAR CASTER WHEEL -->
  <joint name="joint_caster_wheel_back" type="continuous">
    <parent link="caster_part_back"/>
    <child link="caster_wheel_back"/>
    <origin xyz="0 0.044 0.018" rpy="-1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="caster_wheel_back">
    <visual>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_wheel.stl" scale="0.3 0.3 0.3"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <mesh filename="file:///home/yash/ros2_ws/src/task2/meshes/caster_wheel.stl" scale="0.3 0.3 0.3"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>
<gazebo reference="caster_wheel_back">
  <mu1 value="0.1"/>
  <mu2 value="0.1"/>
</gazebo>





  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      
      <left_joint>joint_wheel_left</left_joint>
      <right_joint>joint_wheel_right</right_joint>

      <wheel_separation>0.36</wheel_separation>
      <wheel_diameter>0.2</wheel_diameter>

      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>

      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>
  
  
  
  
</robot>
